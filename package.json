{
  "name": "id-ocr-service",
  "version": "1.0.0",
  "description": "Offline OCR web service for Indian ID documents (PAN, Aadhaar, Voter ID, DL, Passport). 100% local — no cloud OCR.",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js"
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^2.0.0",
    "pdf-to-png-converter": "^3.3.0",
    "sharp": "^0.33.4",
    "tesseract.js": "^5.1.0"
  }
}
